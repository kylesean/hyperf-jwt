{
  "name": "kylesean/hyperf-jwt",
  "description": "A JWT (JSON Web Token) package for Hyperf framework.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "hyperf",
    "jwt",
    "json web token"
  ],
  "authors": [
    {
      "name": "kylesean",
      "email": "jkxsai@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "hyperf/cache": "^3.0 || ^3.1",
    "hyperf/command": "^3.1",
    "hyperf/context": "^3.0 || ^3.1",
    "hyperf/contract": "^3.0 || ^3.1",
    "hyperf/http-server": "^3.1",
    "hyperf/stringable": "^3.0 || ^3.1",
    "lcobucci/jwt": "^5.4",
    "psr/clock": "^1.0",
    "psr/container": "^1.1 || ^2.0",
    "psr/http-message": "^1.1 || ^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^1.0 || ^2.0 || ^3.0",
    "psr/simple-cache": "^2.0 || ^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "hyperf/framework": "^3.0 || ^3.1",
    "hyperf/support": "^3.1",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.0 || ^11.0",
    "swoole/ide-helper": "dev-master",
    "symfony/var-dumper": "^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Kylesean\\Jwt\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kylesean\\Jwt\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist --colors=always",
    "analyse": "phpstan analyse -c phpstan.neon.dist --memory-limit 1024M",
    "cs-fix": "php-cs-fixer fix",
    "cs-check": "php-cs-fixer fix --dry-run --diff"
  },
  "extra": {
    "hyperf": {
      "config": "Kylesean\\Jwt\\ConfigProvider"
    }
  }
}
